           		</commons:ChartContainer>
                   
			    <commons:ChartContainer id="ccAmountbyStatus"
                 		showLegendButton="false" showZoom="false" showLegend="false">
                   	<commons:layoutData>
						<FlexItemData growFactor="1" />
					</commons:layoutData>
                   <commons:content>
                   		<commons:ChartContainerContent>
		               		<commons:content>
								<viz:VizFrame id="vfAmountbyStatus" uiConfig="{applicationSet:'fiori'}"
										visible="{path:'AppData>/reportingType',formatter:'.formatterVisibility.triggerReportingChartsVisibility'}"
						               	height="400px" width="100%" vizType="column"
					               		legendVisible="false">
							         <viz:dataset>
							             <viz.data:FlattenedDataset data="{/results}">
							                 <viz.data:dimensions>
							                     <viz.data:DimensionDefinition name="{i18n>charts.label.status}"
							                         value="{StatusName}">
							                     </viz.data:DimensionDefinition>
							                 </viz.data:dimensions>
							                 <viz.data:measures>
							                     <viz.data:MeasureDefinition name="{i18n>charts.label.amount}"
							                         value="{values}" />
							                 </viz.data:measures>
							             </viz.data:FlattenedDataset>
							         </viz:dataset>
							
							         <viz:feeds>
							             <viz.feeds:FeedItem id='valueAxisFeedAmountbyStatus' uid="valueAxis" type="Measure"
							                 values="{=[${i18n>charts.label.amount}]}" />
							             <viz.feeds:FeedItem id='categoryAxisFeedAmountbyStatus' uid="categoryAxis" type="Dimension"
							                 values="{=[${i18n>charts.label.status}]}" />
						         </viz:feeds>
				           </viz:VizFrame>
                   		</commons:content>
                   	</commons:ChartContainerContent>
                  </commons:content>
               </commons:ChartContainer>
			</items>
			</FlexBox>
			<FlexBox alignItems="Start">
				<items>
 					<commons:ChartContainer id="ccAmountbyIssuingCompany"
                   		showLegendButton="false" showZoom="false" showLegend="false">

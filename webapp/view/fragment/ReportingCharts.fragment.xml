                   		<commons:layoutData>
							<FlexItemData growFactor="1" />
						</commons:layoutData>
                   		<commons:content>
                   			<commons:ChartContainerContent>
		               			<commons:content>
									<viz:VizFrame id="vfAmountbyCreationMode" uiConfig="{applicationSet:'fiori'}"
										visible="true"
					               		height="400px" width="25%" vizType="pie"
					               		legendVisible="false">
					         			<viz:dataset>
							             <viz.data:FlattenedDataset data="{/results}">

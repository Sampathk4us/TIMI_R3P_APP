		</FlexBox>
	</VBox>
	<VBox 
		class="sapUiSmallMargin" 
		visible="{path:'ReportingRequestHeaderList>/results', formatter:'.formatterVisibility.triggerReportingChartsNoDataMessageVisibility'}"
		renderType="Bare" alignItems="Center">
		<Text text="{i18n>request.table.nodata}"></Text>
	</VBox>
	
</core:FragmentDefinition>
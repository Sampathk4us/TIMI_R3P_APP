						</commons:layoutData>
                   		<commons:content>
                   			<commons:ChartContainerContent>
		               			<commons:content>
									<viz:VizFrame id="vfAmountbyIntercoType" uiConfig="{applicationSet:'fiori'}"
										visible="true"
					               		height="400px" width="25%" vizType="pie"
					               		legendVisible="false">
					         			<viz:dataset>
							             <viz.data:FlattenedDataset data="{/results}">
							                 <viz.data:dimensions>
							                     <viz.data:DimensionDefinition 
							                     	name="{i18n>charts.label.intercotype}" value="{IntercoType}" />
							                 </viz.data:dimensions>
							                 <viz.data:measures>

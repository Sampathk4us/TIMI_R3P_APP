							                 values="{=[${i18n>charts.label.amount}]}" />
							             <viz.feeds:FeedItem id='categoryAxisFeedAmountbyReceivingCompany' uid="categoryAxis" type="Dimension"
							                 values="{=[${i18n>charts.label.company}]}" />
							         </viz:feeds>

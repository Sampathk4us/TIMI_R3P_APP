<core:FragmentDefinition
  xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form">
  	<ResponsivePopover placement="Right" showHeader="false"> 
    	<content>
			<HBox class="sapUiContentPadding" width="100%" alignItems="Center" justifyContent="Center">
				<Text id="tRequestActionQuestion" class="sapUiTinyMarginBeginEnd"></Text>
				<Button id="btnDuplicateRequestConfirm" icon="sap-icon://accept" class="sapUiSmallTinyEnd" type="Transparent" press="onPressDuplicateRequestPopupConfirm">
				</Button>
				<Button id="btnDuplicateRequestCancel" icon="sap-icon://decline" class="sapUiSmallMarginEnd" type="Transparent" press="onPressDuplicateRequestPopupCancel">
				</Button>
			</HBox>
		</content>
		<beginButton>
		</beginButton>
		<endButton>
		</endButton>
  	</ResponsivePopover>
</core:FragmentDefinition>
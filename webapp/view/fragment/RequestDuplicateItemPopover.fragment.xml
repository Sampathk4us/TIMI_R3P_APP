<core:FragmentDefinition
  xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form"
  xmlns:custom="cus.fi.timi.rel.assets.js.library">
  	<ResponsivePopover placement="Right" showHeader="false"> 
    	<content>
			<HBox class="sapUiContentPadding" width="100%" alignItems="Center" justifyContent="Center">
				<Text class="sapUiTinyMarginBegin"
					text="{i18n>request.item.text.duplicate}"></Text>
				<custom:NumericInput id="niTimes" class="sapUiTinyMarginBeginEnd" 
					value="1" decimals="0" 
					width="3rem" maxLength="3">
				</custom:NumericInput>
				<Text class="sapUiTinyMarginEnd"
					text="{i18n>request.item.text.duplicate.times}"></Text>
				<Button id="btnConfirmDuplicateRequestItem1" icon="sap-icon://accept" class="sapUiSmallTinyEnd" type="Transparent" press="onPressConfirmDuplicateRequestItem">
				</Button>
				<Button id="btnCancelDuplicateRequestItem1" icon="sap-icon://decline" class="sapUiSmallMarginEnd" type="Transparent" press="onPressCancelDuplicateRequestItem">
				</Button>
			</HBox>
		</content>
		<beginButton>
		</beginButton>
		<endButton>
		</endButton>
  	</ResponsivePopover>
</core:FragmentDefinition>
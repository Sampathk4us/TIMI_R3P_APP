<core:FragmentDefinition
  xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form">
	<layout:VerticalLayout
		width="100%">
		<layout:content>
			<List class="sapUiNoContentPadding" 
				mode="None"
				items="{path:'Request>/WorkflowHistory/results',templateShareable:'Constants>/false'}">
				<CustomListItem class="sapUiTinyMarginTopBottom">
					<HBox>
						<Label class="sapUiTinyMarginBegin"
							text="{path:'Request>TimestampCreation',formatter:'.formatterFormat.formatTimestamp'}" design="Bold"/>
						<core:Icon class="sapUiTinyMarginBegin colorIconSize" 
							src="sap-icon://color-fill" color="{path:'Request>ActionId', formatter: '.formatterState.getActionIconColor'}">
						</core:Icon>
						<Label class="sapUiTinyMarginBegin"
							text="{parts:[{path:'Request>UserCreationName'},{path:'Request>IsSubstitution'},{path:'Request>UserOriginName'}], formatter: '.formatterText.getWFUserText'}"
							design="Bold">
							<customData>
								<core:CustomData key="customTextColor" value="turquoise" writeToDom="true"></core:CustomData>
							</customData>
						</Label>
						<Label
							text="{path:'Request>ActionId', formatter: '.formatterText.getWFActionText'}"
							design="Standard">
							<customData>
								<core:CustomData key="customTextStyle" value="italic" writeToDom="true"></core:CustomData>
							</customData>
						</Label>
						<Label class="workflowComment"
							visible="{= ${Request>Comments} !== '' ? true : false}"
							text=": {Request>Comments}"/>
					</HBox>
				</CustomListItem>
			</List>
		</layout:content>
	</layout:VerticalLayout>
</core:FragmentDefinition>

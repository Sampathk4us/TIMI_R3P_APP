<core:FragmentDefinition
  xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form"
  	xmlns:custom="cus.fi.timi.rel.assets.js.library">
	<Dialog class="sapUiSizeCompact"
		showHeader="false">
		<content>
			<VBox class="sapUiSmallMarginTopBottom"
				width="100%" justifyContent="Center" alignItems="Center">
				<Text id="textLoading" class="sapUiSmallMarginBottom"></Text>
				<BusyIndicator id="biLoading" class="sapUiSmallMarginBottom"/>
				<ProgressIndicator id="piLoading"
					showValue="false"
					state="None"
					visible="false"/>
			</VBox>
		</content>
  	</Dialog>
</core:FragmentDefinition>
<core:FragmentDefinition
  xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form">
  	<ResponsivePopover placement="Right" showHeader="true"> 
  		<customHeader>
  			<Bar class="sapUiSizeCompact">
  				<contentLeft>
  					<Text text=""></Text>
  				</contentLeft>
  				<contentMiddle>
  					<HBox>
  						<core:Icon class="sapUiTinyMarginEnd"
  							src="sap-icon://message-error"
  							color="Negative"></core:Icon>
  						<Title
  							text="{i18n>messagebox.error.title}"></Title>
  					</HBox>
  				</contentMiddle>
  				<contentRight>
  				</contentRight>
  			</Bar>
  		</customHeader>
    	<content>
			<List class="sapUiSizeCompact"
				items="{ItemMessages>/results}" >
				<DisplayListItem
					label="{ItemMessages>message}"/>
			</List>
		</content>
		<beginButton>
		</beginButton>
		<endButton>
		</endButton>
  	</ResponsivePopover>
</core:FragmentDefinition>
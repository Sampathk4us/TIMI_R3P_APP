<core:FragmentDefinition
  xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
  	<ResponsivePopover placement="Right" showHeader="false" class="sapUiSizeCompact timi batchlog"> 
    	<content>
    		<Label class="batchlogTitle"
    			text="{i18n>request.label.batch}"
    			design="Bold"></Label>
			<List
				items="{RequestBatchLogs>/results}"
				mode="None"
				backgroundDesign="Transparent">
				<CustomListItem>
					<HBox
						alignContent="Center" alignItems="Center">
						<Label class="sapUiTinyMarginBegin"
							text="{RequestBatchLogs>CustomField1}" design="Bold"/>
						<Label class="sapUiTinyMarginBegin"
							text="{RequestBatchLogs>CustomField2}" width="100px"/>
						<core:Icon class="sapUiSmallMarginBeginEnd"
							src="{path:'RequestBatchLogs>MessageType',formatter:'.formatterState.getMessageStateIcon'}"
							color="{path:'RequestBatchLogs>MessageType',formatter:'.formatterState.getMessageStateIconColor'}" />
						<Label text="{RequestBatchLogs>Message}"/>
					</HBox>
				</CustomListItem>
			</List>
		</content>
		<beginButton>
		</beginButton>
		<endButton>
		</endButton>
  	</ResponsivePopover>
</core:FragmentDefinition>
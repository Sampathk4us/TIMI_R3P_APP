<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:custom="cus.fi.timi.rel.assets.js.library"
	controllerName="cus.fi.timi.rel.controller.Overview" xmlns:html="http://www.w3.org/1999/xhtml"
	xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<Page title="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterText.getAppTitle'}">
		<customHeader>
			<Toolbar>
				<ToolbarSpacer ></ToolbarSpacer>
				<Title text="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterText.getAppTitle'}"/>
				<ToolbarSpacer ></ToolbarSpacer>
				<Button type="Transparent" press="onPressShowMasterDataDoc"  
				    icon="sap-icon://message-information" 
					text="{i18n>link.masterdatadoc.label}"
					tooltip="{i18n>link.masterdatadoc.tooltip}" />
			</Toolbar>
		</customHeader>
		<content>
			<MessageStrip class="sapUiTinyMarginTopBottom sapUiLargeMarginBeginEnd" text="{path:'AppData>/',formatter:'.formatterText.getDeadlineText'}"
				type="{path:'AppData>/',formatter:'.formatterState.getDeadlineMessageState'}"
				visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerOverviewMessageVisibility'}"
				showIcon="true" showCloseButton="false"></MessageStrip>
			<Toolbar id="tbSearchCriteria" class="sapUiTinyMarginTop sapUiSmallMarginBeginEnd">
				<Title id="tTitleSearchCriteria" text="{i18n>searchcriteria.title}"/>
				<Button id="btnSearchCriteriaVisibility" icon="sap-icon://navigation-up-arrow" type="Transparent" data:displayStateValue="show"
					press="onPressToogleSearchCriteriaVisibility" tooltip="{i18n>searchcriteria.button.tooltip.hide}"></Button>
			</Toolbar>
			<core:Fragment fragmentName="cus.fi.timi.rel.view.fragment.OverviewSearchCriteria" type="XML"/>
			<IconTabBar id="itbRequests" select="onSelectStatus" class="sapUiNoContentPadding">
				<items>
					<IconTabFilter icon="sap-icon://list" iconColor="Default" text="{i18n>request.status.all}" key=" "
						count="{RequestsCount>/CountRequests/NbAll}"></IconTabFilter>
					<IconTabFilter icon="sap-icon://request" iconColor="Default" text="{i18n>request.status.draft}" key="0"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconDraftVisibility'}"
						count="{RequestsCount>/CountRequests/NbDraft}">
						<customData>
							<core:CustomData key="customicontabcolor" value="gray" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-rejections" iconColor="Negative" text="{i18n>request.status.rejected.issuer}" key="3"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconRejectedVisibility'}"
						count="{RequestsCount>/CountRequests/NbRejectedIs}">
						<customData>
							<core:CustomData key="customicontabcolor" value="red" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-rejections" iconColor="Negative" text="{i18n>request.status.rejected.receiver}" key="11"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconRejectedVisibility'}"
						count="{RequestsCount>/CountRequests/NbRejectedRc}">
						<customData>
							<core:CustomData key="customicontabcolor" value="burgundy" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://forward" iconColor="Critical"
						text="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}],formatter:'.formatterText.getStatusSubmittedText'}" key="1"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconSubmittedVisibility'}"
						count="{RequestsCount>/CountRequests/NbSubmitted}">
						<customData>
							<core:CustomData key="customicontabcolor" value="orange" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-approvals" iconColor="Default" text="{i18n>request.status.approved}" key="2"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconApprovedVisibility'}"
						count="{RequestsCount>/CountRequests/NbApproved}">
						<customData>
							<core:CustomData key="customicontabcolor" value="blue" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-approvals" iconColor="Positive" text="{i18n>request.status.validated}" key="9"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconValidatedVisibility'}"
						count="{RequestsCount>/CountRequests/NbValidated}">
						<customData>
							<core:CustomData key="customicontabcolor" value="greenlight" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-approvals" iconColor="Positive" text="{i18n>request.status.validated.receiver}" key="13"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconValidatedVisibility'}"
						count="{RequestsCount>/CountRequests/NbValidatedRc}">
						<customData>
							<core:CustomData key="customicontabcolor" value="green" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://excel-attachment" iconColor="Positive" text="{i18n>request.status.generated}" key="10"
						count="{RequestsCount>/CountRequests/NbGenerated}">
						<customData>
							<core:CustomData key="customicontabcolor" value="greendark" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
				</items>
			</IconTabBar>

<!-- <core:Fragment fragmentName="cus.fi.timi.rel.view.fragment.OverviewTableM" type="XML"/> -->
			<core:Fragment fragmentName="cus.fi.timi.rel.view.fragment.OverviewTableUI" type="XML"/>

			
		</content>
		<footer>
			<Toolbar id="tbFooter">
				<Button id="btnCreateRequest" icon="sap-icon://add" text="{i18n>button.request.create}" press="onPressCreateRequest"
					visible="{AppData>/OverviewActionsVisibility/VisibleCreate}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="gray" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnDownloadTemplate" icon="sap-icon://download" text="{i18n>text.downloadtemplate}"
					tooltip="{i18n>text.downloadtemplate.tooltip}" press="onPressDownloadTemplate" visible="{AppData>/OverviewActionsVisibility/VisibleUpload}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="gray" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnUploadFile" icon="sap-icon://upload" text="{i18n>text.importtxtfile}" press="onPressUploadFileCreationDialog"
					visible="{AppData>/OverviewActionsVisibility/VisibleUpload}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="gray" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<ToolbarSpacer></ToolbarSpacer>
				<Button id="btnSubmitRequests" icon="sap-icon://employee-approvals" text="{i18n>button.request.submit}" press="onPressRequestsAction"
					data:actionId="2" visible="{AppData>/OverviewActionsVisibility/VisibleSubmit}" enabled="{AppData>/overviewActionsEnabled/Submit}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="orange" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<!-- M003 - SRS - Begin of INS - 04/07/2022 -->
				<!--M004 - SRS - Begin of MOD - 28/09/2022-->
				<Button id="btnApproveRequests" icon="sap-icon://employee-approvals" text="{i18n>button.request.approve}" press="onPressRequestsAction"
					data:actionId="3" visible="{AppData>/OverviewActionsVisibility/VisibleApprove}" enabled="{AppData>/overviewActionsEnabled/Approve}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="green" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<!--M004 - SRS - End of MOD - 28/09/2022-->
				<!-- M003 - SRS - End of INS - 04/07/2022 -->
				<Button id="btnValidateRequests" icon="sap-icon://employee-approvals" text="{i18n>button.request.validate}" press="onPressRequestsAction"
					data:actionId="8" visible="{AppData>/OverviewActionsVisibility/VisibleValidate}" enabled="{AppData>/overviewActionsEnabled/Validate}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="green" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnGenerateRequests" icon="sap-icon://excel-attachment" text="{i18n>button.request.generate}" press="onPressRequestsAction"
					data:actionId="9" visible="{AppData>/OverviewActionsVisibility/VisibleGenerate}" enabled="{AppData>/overviewActionsEnabled/Generate}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="green" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnRejectRequests" icon="sap-icon://employee-rejections" text="{i18n>button.request.reject}" press="onPressRequestsAction"
					data:actionId="4" visible="{AppData>/OverviewActionsVisibility/VisibleRejectIssuer}" enabled="{AppData>/overviewActionsEnabled/Reject}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="red" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnDeleteRequests" icon="sap-icon://delete" text="{i18n>button.request.delete}" press="onPressRequestsAction" data:actionId="5"
					visible="{AppData>/OverviewActionsVisibility/VisibleDelete}" enabled="{AppData>/overviewActionsEnabled/Delete}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="red" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
			</Toolbar>
		</footer>
	</Page>
</mvc:View>
<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:custom="cus.fi.timi.rel.assets.js.library"
	controllerName="cus.fi.timi.rel.controller.Overview" xmlns:html="http://www.w3.org/1999/xhtml"
	xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<Page title="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterText.getAppTitle'}">
		<content>
			<MessageStrip class="sapUiTinyMarginTopBottom sapUiLargeMarginBeginEnd" text="{path:'AppData>/',formatter:'.formatterText.getDeadlineText'}"
				type="{path:'AppData>/',formatter:'.formatterState.getDeadlineMessageState'}"
				visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerOverviewMessageVisibility'}"
				showIcon="true" showCloseButton="false"></MessageStrip>
			<Toolbar id="tbSearchCriteria" class="sapUiTinyMarginTop sapUiSmallMarginBeginEnd">
				<Title id="tTitleSearchCriteria" text="{i18n>searchcriteria.title}"/>
				<Button id="btnSearchCriteriaVisibility" icon="sap-icon://navigation-up-arrow" type="Transparent" data:displayStateValue="show"
					press="onPressToogleSearchCriteriaVisibility" tooltip="{i18n>searchcriteria.button.tooltip.hide}"></Button>
			</Toolbar>
			<core:Fragment fragmentName="cus.fi.timi.rel.view.fragment.OverviewSearchCriteria" type="XML"/>
			<IconTabBar id="itbRequests" select="onSelectStatus" class="sapUiNoContentPadding">
				<items>
					<IconTabFilter icon="sap-icon://list" iconColor="Default" text="{i18n>request.status.all}" key=" "
						count="{RequestsCount>/CountRequests/NbAll}"></IconTabFilter>
					<IconTabFilter icon="sap-icon://request" iconColor="Default" text="{i18n>request.status.draft}" key="0"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconDraftVisibility'}"
						count="{RequestsCount>/CountRequests/NbDraft}">
						<customData>
							<core:CustomData key="customicontabcolor" value="gray" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-rejections" iconColor="Negative" text="{i18n>request.status.rejected.issuer}" key="3"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconRejectedVisibility'}"
						count="{RequestsCount>/CountRequests/NbRejectedIs}">
						<customData>
							<core:CustomData key="customicontabcolor" value="red" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-rejections" iconColor="Negative" text="{i18n>request.status.rejected.receiver}" key="11"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconRejectedVisibility'}"
						count="{RequestsCount>/CountRequests/NbRejectedRc}">
						<customData>
							<core:CustomData key="customicontabcolor" value="burgundy" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://forward" iconColor="Critical"
						text="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}],formatter:'.formatterText.getStatusSubmittedText'}" key="1"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconSubmittedVisibility'}"
						count="{RequestsCount>/CountRequests/NbSubmitted}">
						<customData>
							<core:CustomData key="customicontabcolor" value="orange" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-approvals" iconColor="Default" text="{i18n>request.status.approved}" key="2"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconApprovedVisibility'}"
						count="{RequestsCount>/CountRequests/NbApproved}">
						<customData>
							<core:CustomData key="customicontabcolor" value="blue" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-approvals" iconColor="Positive" text="{i18n>request.status.validated}" key="9"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconValidatedVisibility'}"
						count="{RequestsCount>/CountRequests/NbValidated}">
						<customData>
							<core:CustomData key="customicontabcolor" value="greenlight" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://employee-approvals" iconColor="Positive" text="{i18n>request.status.validated.receiver}" key="13"
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerIconValidatedVisibility'}"
						count="{RequestsCount>/CountRequests/NbValidatedRc}">
						<customData>
							<core:CustomData key="customicontabcolor" value="green" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
					<IconTabFilter icon="sap-icon://excel-attachment" iconColor="Positive" text="{i18n>request.status.generated}" key="10"
						count="{RequestsCount>/CountRequests/NbGenerated}">
						<customData>
							<core:CustomData key="customicontabcolor" value="greendark" writeToDom="true"></core:CustomData>
						</customData>
					</IconTabFilter>
				</items>
			</IconTabBar>
			<Table id="tRequests" class="overviewList"
				items="{path:'RequestList>/results', groupHeaderFactory:'.factoryRequestGroupHeader'}" showNoData="true"
				noDataText="{i18n>request.table.nodata}" fixedLayout="false" busyIndicatorDelay="{AppData>/busyIndicatorDelay}">
				<headerToolbar>
					<Toolbar class="sapUiSizeCompact toolbarHeight"
						visible="false">
						<Label class="displayMode" text="{i18n>text.displaymode}"></Label>
						<SegmentedButton id="sbRequestDisplayMode" selectedKey="1" selectionChange="onSelectDisplayMode">
							<items>
								<SegmentedButtonItem icon="sap-icon://multiselect-none" text="{i18n>text.displaymode.list}" key="1"/>
								<SegmentedButtonItem icon="sap-icon://group-2" text="{i18n>text.displaymode.group.uploadfile}" key="2"/>
							</items>
						</SegmentedButton>
						<ToolbarSpacer></ToolbarSpacer>
						<Button type="Transparent" icon="sap-icon://citizen-connect" press="onPressNavigateToSubstitutionApp"
							tooltip="{i18n>request.table.button.substitution.navigate.tooltip}"/>
					</Toolbar>
				</headerToolbar>
				<columns >
					<Column 
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerRequestSelectColumnVisibility'}">
						<CheckBox id="cbSelectAllRequests" select="onSelectAllRequests"></CheckBox>
					</Column>
					<Column  
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerRequestListActionColumnVisibility'}"></Column>
					<Column hAlign="Center" width="0.75rem" visible="{path:'AppData>/appType', formatter:'.businessRules.isAppAccountant'}">
						<core:Icon class="iconActionsOnRequest" src="sap-icon://begin" size="0.75rem"
							color="{path:'AppData>/visibleActionsOnRequestOnly', formatter:'.formatterState.getActionsOnRequestIconColor'}"
							backgroundColor="{path:'AppData>/visibleActionsOnRequestOnly', formatter:'.formatterState.getActionsOnRequestIconBGColor'}"
							press="onPressActionsOnRequest"></core:Icon>
					</Column>
					<Column hAlign="Center" width="5rem" ><Text text="{i18n>request.table.column.request}"/></Column>
					<Column hAlign="Center"  ><Text text="{i18n>request.table.column.status}"/></Column>
					<Column hAlign="Center"  
						visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerAutomaticPostingColumnVisibility'}"></Column>
					<Column hAlign="Center"  ></Column>
					<Column hAlign="Center" ><Text text="{i18n>request.table.column.datecreation}"/></Column>
					<Column hAlign="Center"  visible="{path:'AppData>/intercoType', formatter:'.businessRules.isAppR3P'}">
						<Text text="{i18n>request.table.column.creationmode}"/>
					</Column>
					<Column hAlign="Center" visible="false">
						<Text text="{i18n>request.table.column.majortype}"/>
					</Column>
					<Column hAlign="Center"><Text text="{i18n>request.table.column.invoicetype}"/></Column>
					<Column width="4.5rem" hAlign="Right"><Text text="{i18n>request.table.column.amount}"/></Column>
					<Column width="4.5rem" hAlign="Center" ><Text text="{i18n>request.table.column.currency}"/></Column>
					<Column width="4.5rem" hAlign="Center"><Text text="{i18n>request.table.column.issuingcompany}"/></Column>
					<Column hAlign="Center"><Text text="{i18n>request.table.column.receivingcompany}"/></Column>
					<Column  hAlign="Left"><Text text="{i18n>request.table.column.headertext}"/></Column>
					<Column >
						<HBox>
							<Button type="Transparent" icon="sap-icon://refresh" press="onPressRefreshResquestsList"
								visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerAutomaticPostingColumnVisibility'}"/>
							<Button type="Transparent" icon="sap-icon://citizen-connect" press="onPressNavigateToSubstitutionApp"
								visible="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'}], formatter:'.formatterVisibility.triggerNavigateToSubstitutionButtonVisibility'}"
								tooltip="{i18n>request.table.button.substitution.navigate.tooltip}"/>
						</HBox>
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="onPressNavigateToRequestDetails"
						tooltip="{parts:[{path:'RequestList>Substitution/IsSubstitution'},{path:'RequestList>Substitution/Fullname'},{path:'RequestList>Substitution/DateBegin'},{path:'RequestList>Substitution/DateEnd'}],formatter:'.formatterText.getSubstituteRequestTooltip'}">
						<customData>
							<core:CustomData key="isSubstitution"
								value="{path:'RequestList>Substitution/IsSubstitution',formatter:'.formatterState.getRequestSubstitutionState'}" writeToDom="true"></core:CustomData>
						</customData>
						<cells>
							<CheckBox id="cbSelectRequest" visible="{RequestList>Filters/IsSelectable}" selected="{RequestList>Filters/IsSelected}"
								select="onSelectRequest"></CheckBox>
							<HBox>
								<Button id="btnCopyRequest" icon="sap-icon://duplicate" type="Transparent" tooltip="{i18n>button.request.copy.tooltip}"
									press="onPressDuplicateRequest" visible="{RequestList>Actions/VisibleCopy}"></Button>
								<Button id="btnDeleteRequest" icon="sap-icon://delete" type="Transparent" tooltip="{i18n>button.request.delete.tooltip}"
									press="onPressDeleteRequest" visible="{RequestList>Actions/VisibleDelete}"></Button>
							</HBox>
							<core:Icon src="sap-icon://begin" useIconTooltip="true" size="0.65rem" visible="{RequestList>Filters/HasActions}"></core:Icon>
							<ObjectIdentifier title="{RequestList>RequestId}"/>
							<ObjectStatus
								text="{parts:[{path:'AppData>/intercoType'},{path:'AppData>/appType'},{path:'RequestList>StatusId'}],formatter:'.formatterText.getStatusText'}">
								<customData>
									<core:CustomData key="customobjectstatus" value="{path:'RequestList>StatusId', formatter:'.formatterState.getCustomStatusState'}"
										writeToDom="true"></core:CustomData>
								</customData>
							</ObjectStatus>
							<core:Icon
								src="{parts:[{path:'AppData>/appType'},{path:'RequestList>HeaderData'}], formatter:'.formatterState.getAutomaticIntegrationIcon'}"
								size="0.85rem"
								tooltip="{parts:[{path:'AppData>/appType'},{path:'RequestList>HeaderData'}], formatter:'.formatterText.getAutomaticIntegrationTooltip'}"
								color="{parts:[{path:'AppData>/appType'},{path:'RequestList>HeaderData'}], formatter:'.formatterState.getAutomaticIntegrationIconColor'}"
								press="onPressShowRequestBatchLogs"></core:Icon>
							<Button id="btnShowRequestHistory" icon="sap-icon://workflow-tasks" type="Transparent" tooltip="{i18n>button.request.showhistory.tooltip}"
								press="onPressShowRequestHistory"></Button>
							<Text text="{path:'RequestList>DateCreation',formatter:'.formatterFormat.formatDate'}"/>
							<Text text="{RequestList>HeaderData/Descriptions/CreationModeName}"/>
							<Text text="{RequestList>HeaderData/Descriptions/MajorTypeName}"/>
							<Text text="{RequestList>HeaderData/Descriptions/DocumentTypeName}"/>
							<Text text="{path:'RequestList>HeaderData/Amount',formatter:'.formatterFormat.formatAmount'}"/>
							<Text text="{RequestList>HeaderData/CurrencyCode}"/>
							<Text text="{RequestList>HeaderData/IsLegalEntityCode} / {RequestList>HeaderData/IsCompanyCode}"/>
							<Text text="{RequestList>HeaderData/RcLegalEntityCode} / {RequestList>HeaderData/RcCompanyCode}"/>
							<Text text="{RequestList>HeaderData/HeaderText}"/>
							<Button id="btnShowRequestHeaderData" icon="sap-icon://search" type="Transparent" tooltip="{i18n>button.request.showheaderdata.tooltip}"
								press="onPressShowRequestHeaderData"></Button>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Toolbar id="tbFooter">
				<Button id="btnCreateRequest" icon="sap-icon://add" text="{i18n>button.request.create}" press="onPressCreateRequest"
					visible="{AppData>/OverviewActionsVisibility/VisibleCreate}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="gray" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnDownloadTemplate" icon="sap-icon://download" text="{i18n>text.downloadtemplate}"
					tooltip="{i18n>text.downloadtemplate.tooltip}" press="onPressDownloadTemplate" visible="{AppData>/OverviewActionsVisibility/VisibleUpload}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="gray" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnUploadFile" icon="sap-icon://upload" text="{i18n>text.importtxtfile}" press="onPressUploadFileCreationDialog"
					visible="{AppData>/OverviewActionsVisibility/VisibleUpload}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="gray" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<ToolbarSpacer></ToolbarSpacer>
				<Button id="btnSubmitRequests" icon="sap-icon://employee-approvals" text="{i18n>button.request.submit}" press="onPressRequestsAction"
					data:actionId="2" visible="{AppData>/OverviewActionsVisibility/VisibleSubmit}" enabled="{AppData>/overviewActionsEnabled/Submit}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="orange" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<!-- M003 - SRS - Begin of INS - 04/07/2022 -->
				<!--M004 - SRS - Begin of MOD - 28/09/2022-->
				<Button id="btnApproveRequests" icon="sap-icon://employee-approvals" text="{i18n>button.request.approve}" press="onPressRequestsAction"
					data:actionId="3" visible="{AppData>/OverviewActionsVisibility/VisibleApprove}" enabled="{AppData>/overviewActionsEnabled/Approve}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="green" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<!--M004 - SRS - End of MOD - 28/09/2022-->
				<!-- M003 - SRS - End of INS - 04/07/2022 -->
				<Button id="btnValidateRequests" icon="sap-icon://employee-approvals" text="{i18n>button.request.validate}" press="onPressRequestsAction"
					data:actionId="8" visible="{AppData>/OverviewActionsVisibility/VisibleValidate}" enabled="{AppData>/overviewActionsEnabled/Validate}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="green" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnGenerateRequests" icon="sap-icon://excel-attachment" text="{i18n>button.request.generate}" press="onPressRequestsAction"
					data:actionId="9" visible="{AppData>/OverviewActionsVisibility/VisibleGenerate}" enabled="{AppData>/overviewActionsEnabled/Generate}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="green" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnRejectRequests" icon="sap-icon://employee-rejections" text="{i18n>button.request.reject}" press="onPressRequestsAction"
					data:actionId="4" visible="{AppData>/OverviewActionsVisibility/VisibleRejectIssuer}" enabled="{AppData>/overviewActionsEnabled/Reject}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="red" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
				<Button id="btnDeleteRequests" icon="sap-icon://delete" text="{i18n>button.request.delete}" press="onPressRequestsAction" data:actionId="5"
					visible="{AppData>/OverviewActionsVisibility/VisibleDelete}" enabled="{AppData>/overviewActionsEnabled/Delete}">
					<customData>
						<core:CustomData key="custombuttoncolor" value="red" writeToDom="true"></core:CustomData>
					</customData>
				</Button>
			</Toolbar>
		</footer>
	</Page>
</mvc:View>